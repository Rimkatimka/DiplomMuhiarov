<Window x:Class="EnergyMeteringSystem.App.Views.Meters.MeterEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:EnergyMeteringSystem.App.Helpers"
        Title="Регистрация счетчика" 
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Серийный номер -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Серийный номер:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" 
                 MaxLength="30"
                 Text="{Binding SerialNumber}" 
                 Margin="5" Padding="5"
                 PreviewTextInput="TextBox_PreviewTextInput_Alphanumeric"
                 PreviewKeyDown="TextBox_PreviewKeyDown_BlockSpace"/>

        <!-- Тип счетчика -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип счетчика:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="1" Grid.Column="1" 
                  ItemsSource="{Binding MeterTypes}"
                  SelectedItem="{Binding SelectedMeterType}"
                  DisplayMemberPath="Name"
                  Margin="5" Padding="5"/>

        <!-- Объект установки -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Объект установки:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  ItemsSource="{Binding Objects}"
                  SelectedItem="{Binding SelectedObject}"
                  DisplayMemberPath="Address"
                  IsEnabled="{Binding IsObjectEnabled}"
                  Margin="5" Padding="5"/>

        <!-- Дата установки -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата установки:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker x:Name="InstallationDatePicker" 
                    Grid.Row="3" Grid.Column="1" 
                    SelectedDate="{Binding InstallationDate}"
                    DisplayDateStart="{Binding MinInstallationDate, Mode=OneWay}"
                    DisplayDateEnd="{Binding MaxInstallationDate, Mode=OneWay}"
                    Margin="5" Padding="5"/>

        <!-- Начальные показания -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Начальные показания:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" 
                 Text="{Binding InitialReading}" 
                 Margin="5" Padding="5"
                 MaxLength="10"
                 PreviewTextInput="TextBox_PreviewTextInput_Decimal"
                 PreviewKeyDown="TextBox_PreviewKeyDown_BlockSpace"
                 ToolTip="Максимум 99 999,999"/>

        <!-- Дата последней поверки -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата последней поверки:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker x:Name="LastVerificationDatePicker" 
                Grid.Row="5" Grid.Column="1" 
                SelectedDate="{Binding LastVerificationDate}"
                DisplayDateStart="{Binding MinLastVerificationDate, Mode=OneWay}"
                DisplayDateEnd="{Binding MaxLastVerificationDate, Mode=OneWay}"
                IsEnabled="{Binding IsEditMode}"
                Margin="5" Padding="5"/>

        <!-- Дата следующей поверки -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата следующей поверки:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker x:Name="NextVerificationDatePicker" 
                Grid.Row="6" Grid.Column="1" 
                SelectedDate="{Binding NextVerificationDate}"
                DisplayDateStart="{Binding MinNextVerificationDate, Mode=OneWay}"
                DisplayDateEnd="{Binding MaxNextVerificationDate, Mode=OneWay}"
                Margin="5" Padding="5"/>

        <!-- Срок службы -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Срок службы (лет):" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="7" Grid.Column="1" 
                 Text="{Binding ServiceLifeYears}" 
                 Margin="5" Padding="5"
                 MaxLength="3"
                 IsReadOnly="True"
                 Background="#F0F0F0"
                 PreviewTextInput="TextBox_PreviewTextInput_NumbersOnly"
                 PreviewKeyDown="TextBox_PreviewKeyDown_BlockSpace"/>

        <!-- Дата изъятия (авто) -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Дата изъятия (авто):" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="8" Grid.Column="1" 
                 Text="{Binding RemovalDate, StringFormat={}{0:dd.MM.yyyy}, TargetNullValue=—}" 
                 Margin="5" Padding="5"
                 IsReadOnly="True"
                 Background="#F5F5F5"
                 Foreground="Gray"/>

        <!-- Статус счетчика -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Статус:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="9" Grid.Column="1" 
                  ItemsSource="{Binding Statuses}"
                  SelectedItem="{Binding SelectedStatus}"
                  DisplayMemberPath="Name"
                  Margin="5" Padding="5"/>

        <!-- Сообщение об ошибке -->
        <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" 
                   Text="{Binding DateError}"
                   Foreground="Red"
                   FontSize="12"
                   Margin="5"
                   HorizontalAlignment="Center"
                   Visibility="{Binding HasDateError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Command="{Binding SaveCommand}"
                    Padding="20,8" Margin="5"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Отмена" 
                    Command="{Binding CancelCommand}"
                    Padding="20,8" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>