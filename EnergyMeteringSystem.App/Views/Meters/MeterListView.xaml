<UserControl x:Class="EnergyMeteringSystem.App.Views.Meters.MeterListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска и фильтров -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="250" 
                     Padding="5"
                     ToolTip="Поиск по серийному номеру"
                     VerticalAlignment="Center"/>

            <ComboBox ItemsSource="{Binding Statuses}" 
                      SelectedItem="{Binding SelectedStatus}"
                      DisplayMemberPath="Name"
                      Width="150"
                      Margin="10,0,0,0"
                      Padding="5"
                      ToolTip="Фильтр по статусу"/>

            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}" 
                    Margin="10,0,0,0"
                    Padding="10,5"/>
        </StackPanel>

        <!-- Таблица счетчиков -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding FilteredMeters}"
                  SelectedItem="{Binding SelectedMeter}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Серийный номер" Binding="{Binding SerialNumber}" Width="150"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding MeterTypeName}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                <DataGridTextColumn Header="Дата установки" Binding="{Binding InstallationDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTextColumn Header="След. поверка" Binding="{Binding NextVerificationDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style>
                            <Setter Property="TextBlock.Foreground" Value="{Binding VerificationStatusColor}"/>
                            <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" 
                    Command="{Binding AddCommand}"
                    Padding="15,5" Margin="5"/>
            <Button Content="Редактировать" 
                    Command="{Binding EditCommand}"
                    Padding="15,5" Margin="5"/>
            <Button Content="Замена" 
                    Command="{Binding ReplaceCommand}"
                    Padding="15,5" Margin="5"
                    Background="#FF9800" Foreground="White"/>
        </StackPanel>
    </Grid>
</UserControl>