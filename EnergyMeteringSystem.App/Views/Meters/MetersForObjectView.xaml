<Window x:Class="EnergyMeteringSystem.App.Views.Meters.MetersForObjectView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Счётчики объекта" 
        Height="500" Width="900"
        MinHeight="400"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}"/>
        <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация об объекте -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <TextBlock Text="{Binding ObjectAddress}" 
                       FontSize="14" 
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Таблица счётчиков -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Meters}"
                  SelectedItem="{Binding SelectedMeter}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  AlternatingRowBackground="#F5F5F5"
                  AlternationCount="2"
                  BorderBrush="LightGray"
                  BorderThickness="1"
                  RowHeaderWidth="0"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Серийный номер" 
                                    Binding="{Binding SerialNumber}" 
                                    Width="140"/>

                <DataGridTextColumn Header="Тип" 
                                    Binding="{Binding MeterTypeName}" 
                                    Width="130"/>

                <DataGridTextColumn Header="Дата установки" 
                                    Binding="{Binding InstallationDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Поверка до" 
                                    Binding="{Binding NextVerificationDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Статус" 
                                    Binding="{Binding StatusName}" 
                                    Width="90"/>

                <DataGridTextColumn Header="Срок службы" 
                                    Binding="{Binding ServiceLifeText}" 
                                    Width="90"/>

                <DataGridTextColumn Header="Дата изъятия" 
                                    Binding="{Binding RemovalDateText}" 
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" 
                    Command="{Binding AddMeterCommand}"
                    Padding="15,8"
                    Margin="5"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>

            <Button Content="Редактировать" 
                    Command="{Binding EditMeterCommand}"
                    Padding="15,8"
                    Margin="5"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>

            <Button Content="Удалить" 
                    Command="{Binding DeleteMeterCommand}"
                    Padding="15,8"
                    Margin="5"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>

            <Button Content="Закрыть" 
                    Click="CloseButton_Click"
                    Padding="15,8"
                    Margin="5"
                    Background="#9E9E9E"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>