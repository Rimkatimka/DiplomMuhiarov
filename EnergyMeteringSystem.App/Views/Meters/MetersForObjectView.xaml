<Window x:Class="EnergyMeteringSystem.App.Views.Meters.MetersForObjectView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Счётчики объекта" 
        Height="500" Width="800"
        MinHeight="250"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация об объекте -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <TextBlock Text="{Binding ObjectAddress}" 
                       FontSize="14" 
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Таблица счётчиков -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Meters}"
                  SelectedItem="{Binding SelectedMeter}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  AlternatingRowBackground="#F5F5F5"
                  BorderBrush="LightGray"
                  BorderThickness="1">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Серийный номер" Binding="{Binding SerialNumber}" Width="150"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding MeterTypeName}" Width="150"/>
                <DataGridTextColumn Header="Дата установки" Binding="{Binding InstallationDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTextColumn Header="Поверка до" Binding="{Binding NextVerificationDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                <DataGridTextColumn Header="Срок службы" Binding="{Binding ServiceLifeText}" Width="100"/>
                <DataGridTextColumn Header="Дата изъятия" Binding="{Binding RemovalDateText}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" 
                    Command="{Binding AddMeterCommand}"
                    Padding="15,8"
                    Margin="5"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>

            <Button Content="Редактировать" 
                    Command="{Binding EditMeterCommand}"
                    Padding="15,8"
                    Margin="5"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>

            <Button Content="Удалить" 
                    Command="{Binding DeleteMeterCommand}"
                    Padding="15,8"
                    Margin="5"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>

            <Button Content="Закрыть" 
                    Click="CloseButton_Click"
                    Padding="15,8"
                    Margin="5"
                    Background="#9E9E9E"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>