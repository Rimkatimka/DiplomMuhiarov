<UserControl x:Class="EnergyMeteringSystem.App.Views.Directories.DirectoryListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" Padding="5"
                     VerticalAlignment="Center"/>
            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}" 
                    Margin="10,0,0,0"
                    Padding="10,5"/>
        </StackPanel>

        <!-- Список -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" 
                    Command="{Binding AddCommand}"
                    Padding="15,5" Margin="5"/>
            <Button Content="Редактировать" 
                    Command="{Binding EditCommand}"
                    Padding="15,5" Margin="5"/>
            <Button Content="Удалить" 
                    Command="{Binding DeleteCommand}"
                    Padding="15,5" Margin="5"
                    Background="#F44336" Foreground="White"/>
        </StackPanel>
    </Grid>
</UserControl>