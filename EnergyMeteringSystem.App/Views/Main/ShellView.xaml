<Window x:Class="EnergyMeteringSystem.App.Views.Main.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет электроэнергии" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        MinHeight="650"
        MinWidth="900"
        xmlns:local="clr-namespace:EnergyMeteringSystem.App.ViewModels.Main">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель с меню -->
        <Border Grid.Column="0" Background="#2D3F5E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Имя пользователя -->
                <StackPanel Grid.Row="0" Background="#1F2A40" Margin="10">
                    <TextBlock Text="Пользователь:" Foreground="#AAAAAA" FontSize="11"/>
                    <TextBlock Text="{Binding CurrentUser.DisplayName}" 
                               Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentUser.RoleText}" 
                               Foreground="#4CAF50" FontSize="12"/>
                </StackPanel>

                <!-- TreeView меню -->
                <TreeView Grid.Row="1" 
                          ItemsSource="{Binding MenuItems}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="White">

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type local:MenuItemViewModel}" 
                                                  ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}" Margin="10,5" FontSize="14"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1F2A40"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <!-- Кнопка выхода -->
                <Button Grid.Row="2" 
                        Content="Выйти"
                        Command="{Binding LogoutCommand}"
                        Background="#F44336"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="10"
                        Margin="10"
                        HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>

        <!-- Правая область - Контейнер для View -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>
