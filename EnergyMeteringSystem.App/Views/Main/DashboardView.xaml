<UserControl x:Class="EnergyMeteringSystem.App.Views.Main.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>

            <!-- Карточки с показателями -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Карточка 1 -->
                <Border Grid.Column="0" Background="#2196F3" Padding="20" Margin="5" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Объекты" Foreground="White" FontSize="14"/>
                        <TextBlock Text="{Binding TotalObjects}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Карточка 2 -->
                <Border Grid.Column="1" Background="#4CAF50" Padding="20" Margin="5" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Счётчики" Foreground="White" FontSize="14"/>
                        <TextBlock Text="{Binding TotalMeters}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Карточка 3 -->
                <Border Grid.Column="2" Background="#FF9800" Padding="20" Margin="5" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Показаний сегодня" Foreground="White" FontSize="14"/>
                        <TextBlock Text="{Binding ReadingsToday}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Карточка 4 -->
                <Border Grid.Column="3" Background="#F44336" Padding="20" Margin="5" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Поверка истекла" Foreground="White" FontSize="14"/>
                        <TextBlock Text="{Binding ExpiredMeters}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Второй ряд карточек -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Карточка 5 -->
                <Border Grid.Column="0" Background="#9C27B0" Padding="20" Margin="5" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Начислено за месяц" Foreground="White" FontSize="14"/>
                        <TextBlock Text="{Binding AccrualMonth}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Карточка 6 -->
                <Border Grid.Column="1" Background="#009688" Padding="20" Margin="5" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Оплачено за месяц" Foreground="White" FontSize="14"/>
                        <TextBlock Text="{Binding PaymentMonth}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- График потребления -->
            <Border Background="#F5F5F5" Padding="20" Margin="0,20,0,0" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Динамика потребления" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <ItemsControl ItemsSource="{Binding ChartData}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,0">
                                    <Border Background="#2196F3" 
                                            Width="40" 
                                            Height="100"
                                            CornerRadius="5,5,0,0"
                                            VerticalAlignment="Bottom"/>
                                    <TextBlock Text="{Binding Label}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding Value, StringFormat={}{0:F0}}" HorizontalAlignment="Center" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ТОП должников -->
            <Border Background="#F5F5F5" Padding="20" Margin="0,20,0,0" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="ТОП-5 должников" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <DataGrid ItemsSource="{Binding TopDebtors}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*"/>
                            <DataGridTextColumn Header="Сумма долга" Binding="{Binding DebtAmount, StringFormat={}{0:F2} ₽}" Width="150"/>
                            <DataGridTextColumn Header="Период" Binding="{Binding PeriodMonth}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>