<UserControl x:Class="EnergyMeteringSystem.App.Views.Readings.MeterReadingInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Поиск по адресу -->
            <GroupBox Grid.Row="0" Header="Поиск объекта" Margin="0,0,0,10">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="5"
                         MaxLength="50"
                         ToolTip="Введите адрес для поиска"/>
            </GroupBox>

            <!-- Таблица объектов (выбор по клику) -->
            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding FilteredObjects}"
                      SelectedItem="{Binding SelectedObject}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      MaxHeight="200"
                      Margin="0,0,0,10"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*" MinWidth="200"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding ObjectTypeName}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Площадь" Binding="{Binding TotalArea, StringFormat={}{0:F1} м²}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Жильцы" Binding="{Binding ResidentCount}" Width="Auto" MinWidth="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Счетчики выбранного объекта -->
            <GroupBox Grid.Row="2" Header="Счетчики" Margin="0,0,0,10"
                      Visibility="{Binding HasSelectedObject, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ListBox ItemsSource="{Binding Meters}" 
                     SelectedItem="{Binding SelectedMeter}"
                     Height="80" Margin="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding SerialNumber}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding MeterTypeName}" FontSize="10"/>
                                <TextBlock Text="{Binding LastReadingInfo}" 
                           FontSize="10" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Ввод показаний с автоматическим периодом -->
            <!-- Ввод показаний с автоматическим периодом -->
            <GroupBox Grid.Row="3" Header="Ввод показаний" Margin="0,0,0,10"
          Visibility="{Binding HasSelectedMeter, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Период:" Margin="5" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="📅 " VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PeriodDisplay}" 
                       VerticalAlignment="Center"
                       FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text=" (ввод за этот период)" 
                       FontSize="10" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Показание:" Margin="5" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" 
                 Text="{Binding ReadingValue}" 
                 Margin="5" Padding="5"
                 MaxLength="15"
                 Width="150" HorizontalAlignment="Left"
                 PreviewTextInput="TextBox_PreviewTextInput_Decimal"
                 PreviewKeyDown="TextBox_PreviewKeyDown_BlockSpace"
                 ToolTip="Только цифры, точка или запятая"/>
                </Grid>
            </GroupBox>

            <!-- Последнее показание -->
            <Border Grid.Row="4" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,10"
        Visibility="{Binding HasLastReading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Последнее показание:" FontWeight="Bold" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <Button Content="Подставить"
                    Command="{Binding SetLastReadingCommand}"
                    Padding="10,3"
                    Margin="0,0,0,10"
                    Background="#2196F3"
                    Foreground="White"
                    FontSize="11"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LastReading.Value, StringFormat=Показание: {0:F2}}"/>
                    <TextBlock Text="{Binding LastReading.ReadingDate, StringFormat=Дата: {0:dd.MM.yyyy}}"/>
                    <TextBlock Text="{Binding LastReading.Consumption, StringFormat=Потребление: {0:F2} кВт}"/>
                </StackPanel>
            </Border>

            <!-- История показаний -->
            <GroupBox Grid.Row="5" Header="История показаний" Margin="0,0,0,10"
                      Visibility="{Binding HasReadingHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DataGrid ItemsSource="{Binding ReadingHistory}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MaxHeight="150"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding ReadingDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                        <DataGridTextColumn Header="Показание" Binding="{Binding Value}" Width="100"/>
                        <DataGridTextColumn Header="Потребление" Binding="{Binding Consumption, StringFormat={}{0:F2} кВт}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Предупреждение -->
            <TextBlock Grid.Row="6" Text="{Binding WarningMessage}" 
                       Foreground="Red" FontWeight="Bold"
                       Margin="5" HorizontalAlignment="Center"
                       Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                <Button Content="Сохранить" 
                        Command="{Binding SaveCommand}" 
                        Padding="20,5" Margin="5" Width="100"
                        Background="#4CAF50" Foreground="White"/>
                <Button Content="Очистить" 
                        Command="{Binding ClearCommand}" 
                        Padding="20,5" Margin="5" Width="100"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>