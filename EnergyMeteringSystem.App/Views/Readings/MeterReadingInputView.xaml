<UserControl x:Class="EnergyMeteringSystem.App.Views.Readings.MeterReadingInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск объекта -->
        <GroupBox Grid.Row="0" Header="Поиск объекта" Margin="0,0,0,10">
            <StackPanel>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
         Margin="5" Padding="5"
         ToolTip="Введите адрес для поиска"/>
                <ListBox ItemsSource="{Binding FoundObjects}" 
                         SelectedItem="{Binding SelectedObject}"
                         DisplayMemberPath="Address"
                         Height="100" Margin="5"
                         ToolTip="Выберите объект из списка"/>
            </StackPanel>
        </GroupBox>

        <!-- Счетчики объекта (появляются после выбора объекта) -->
        <GroupBox Grid.Row="1" Header="Счетчики" Margin="0,0,0,10"
                  Visibility="{Binding HasSelectedObject, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ListBox ItemsSource="{Binding Meters}" 
                     SelectedItem="{Binding SelectedMeter}"
                     Height="80" Margin="5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding SerialNumber}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding MeterTypeName}" FontSize="10"/>
                            <TextBlock Text="{Binding LastReadingInfo}" 
                                       FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- Ввод показаний (появляется после выбора счетчика) -->
        <GroupBox Grid.Row="2" Header="Ввод показаний" Margin="0,0,0,10"
                  Visibility="{Binding HasSelectedMeter, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата:" Margin="5" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="0" Grid.Column="1" 
                            SelectedDate="{Binding ReadingDate}" 
                            Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Показание:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                         Text="{Binding ReadingValue}" 
                         Margin="5" Padding="5"/>
            </Grid>
        </GroupBox>

        <!-- Предупреждение об аномалии -->
        <TextBlock Grid.Row="3" Text="{Binding WarningMessage}" 
                   Foreground="Red" FontWeight="Bold"
                   Margin="5" HorizontalAlignment="Center"
                   Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="Сохранить" 
                    Command="{Binding SaveCommand}" 
                    Padding="20,5" Margin="5" Width="100"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Очистить" 
                    Command="{Binding ClearCommand}" 
                    Padding="20,5" Margin="5" Width="100"/>
        </StackPanel>
    </Grid>
</UserControl>