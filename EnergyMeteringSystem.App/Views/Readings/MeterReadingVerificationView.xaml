<UserControl x:Class="EnergyMeteringSystem.App.Views.Readings.MeterReadingVerificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Обновить" Command="{Binding RefreshCommand}" Padding="10,5" Margin="5"/>
            <CheckBox Content="Пакетный режим" IsChecked="{Binding IsBatchMode}" Margin="15,5,5,5"/>
            <Button Content="Выбрать все" Command="{Binding SelectAllCommand}" 
                    Visibility="{Binding IsBatchMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="10,5" Margin="5"/>
        </StackPanel>

        <!-- Таблица показаний -->
        <DataGrid Grid.Row="1" 
          ItemsSource="{Binding Readings}"
          SelectedItem="{Binding SelectedReading}"
          AutoGenerateColumns="False"
          SelectionMode="Single"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <!-- Чекбокс для пакетного режима -->
                <DataGridCheckBoxColumn Header="✓" 
                                Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="50"
                                Visibility="{Binding DataContext.IsBatchMode, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="Счётчик" Binding="{Binding SerialNumber}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding ReadingDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Показание" Binding="{Binding Value}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Предыдущее" Binding="{Binding PreviousValue}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ввёл" Binding="{Binding EnteredBy}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Время" Binding="{Binding EnteredAt, StringFormat={}{0:HH:mm}}" Width="80" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Подтвердить" 
                    Command="{Binding VerifyCommand}"
                    Padding="20,5" Margin="5" Width="120"
                    Background="#4CAF50" Foreground="White"/>

            <Button Content="Отклонить" 
                    Command="{Binding RejectCommand}"
                    Padding="20,5" Margin="5" Width="120"
                    Background="#F44336" Foreground="White"/>
        </StackPanel>

        <!-- Панель отклонения (появляется при нажатии "Отклонить") -->
        <Border Grid.Row="2" Background="#FFF0F0" Padding="10" 
                Visibility="{Binding IsRejectionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Причина отклонения:" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding RejectionReasons}" 
                          SelectedItem="{Binding SelectedReason}"
                          DisplayMemberPath="Name"
                          Margin="0,5"/>

                <TextBlock Text="Комментарий:" Margin="0,5,0,0"/>
                <TextBox Text="{Binding RejectionComment}" 
                         AcceptsReturn="True" 
                         MinHeight="60"
                         Margin="0,5"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Отмена" Command="{Binding CancelRejectCommand}" Margin="5" Padding="10,5"/>
                    <Button Content="Подтвердить отклонение" 
                            Command="{Binding ConfirmRejectCommand}"
                            Background="#F44336" Foreground="White"
                            Padding="15,5" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>