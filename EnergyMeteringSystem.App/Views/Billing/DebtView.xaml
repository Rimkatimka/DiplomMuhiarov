<UserControl x:Class="EnergyMeteringSystem.App.Views.Billing.DebtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и поиск -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Должники" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" 
                     Margin="20,0,0,0"
                     Padding="5"
                     VerticalAlignment="Center"/>

            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}"
                    Margin="10,0,0,0"
                    Padding="10,5"/>
        </StackPanel>

        <!-- Статистика -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Border Background="#F44336" Padding="10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Общая сумма долга" Foreground="White" FontSize="12"/>
                    <TextBlock Text="{Binding TotalDebt, StringFormat={}{0:F2} ₽}" 
                               Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#2196F3" Padding="10" CornerRadius="5" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Количество должников" Foreground="White" FontSize="12"/>
                    <TextBlock Text="{Binding DebtorsCount}" 
                               Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Список должников -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Debts}"
                  SelectedItem="{Binding SelectedDebt}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="300"/>
                <DataGridTextColumn Header="Сумма долга" Binding="{Binding DebtAmount, StringFormat={}{0:F2} ₽}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style>
                            <Setter Property="TextBlock.Foreground" Value="#F44336"/>
                            <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Период" Binding="{Binding PeriodMonth}" Width="100"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PeriodYear}" Width="80"/>
                <DataGridTextColumn Header="Последний платёж" Binding="{Binding LastPaymentDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTextColumn Header="Месяцев просрочки" Binding="{Binding MonthsOverdue}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка действия -->
        <Button Grid.Row="3" 
                Content="Отметить оплату"
                Command="{Binding MarkAsPaidCommand}"
                HorizontalAlignment="Right"
                Padding="20,5"
                Margin="0,10,0,0"
                Background="#4CAF50" Foreground="White"/>
    </Grid>
</UserControl>