<UserControl x:Class="EnergyMeteringSystem.App.Views.Billing.AccrualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель выбора периода -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Год:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Years}" 
                      SelectedItem="{Binding SelectedYear}"
                      Width="80" Margin="5"/>

            <TextBlock Text="Месяц:" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <ComboBox ItemsSource="{Binding Months}" 
                      SelectedIndex="{Binding SelectedMonth,Mode=OneTime}"
                      Width="100" Margin="5"/>

            <Button Content="Рассчитать" 
                    Command="{Binding CalculateCommand}"
                    Padding="10,5" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Результаты расчёта -->
        <GroupBox Grid.Row="1" Header="Результаты расчёта" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" 
                          ItemsSource="{Binding Calculations}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Height="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="300"/>
                        <DataGridTextColumn Header="Потребление" Binding="{Binding TotalConsumption}" Width="100"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:F2} ₽}" Width="100"/>
                        <DataGridTextColumn Header="Показаний" Binding="{Binding ReadingsCount}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Есть начисление" Binding="{Binding HasExistingAccrual}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <TextBlock Text="Итого: " FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:F2} ₽}" 
                               FontWeight="Bold" FontSize="16" Foreground="Green"/>

                    <Button Content="Сохранить выбранное" 
                            Command="{Binding SaveCommand}"
                            Padding="15,5" Margin="20,0,0,0"
                            Background="#4CAF50" Foreground="White"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Существующие начисления -->
        <GroupBox Grid.Row="2" Header="Существующие начисления">
            <DataGrid ItemsSource="{Binding ExistingAccruals}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="300"/>
                    <DataGridTextColumn Header="Потребление" Binding="{Binding ConsumptionValue}" Width="100"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:F2} ₽}" Width="100"/>
                    <DataGridTextColumn Header="Период" Binding="{Binding PeriodMonth, Mode=OneTime}" Width="100"/>
                    <DataGridCheckBoxColumn Header="Оплачено" Binding="{Binding IsPaid}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>