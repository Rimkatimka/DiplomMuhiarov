<Window x:Class="EnergyMeteringSystem.App.Views.Billing.ReceiptView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Квитанция" 
        Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border BorderBrush="Black" BorderThickness="1" Margin="10" Padding="15">
        <StackPanel>
            <!-- Шапка -->
            <TextBlock Text="КВИТАНЦИЯ" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding ReceiptNumber}" FontSize="12" HorizontalAlignment="Center"/>
            <TextBlock Text="от {Binding PaymentDate}" FontSize="12" HorizontalAlignment="Center"/>

            <Line X1="0" Y1="10" X2="400" Y2="10" Stroke="Black" StrokeThickness="1" Margin="0,10"/>

            <!-- Абонент -->
            <TextBlock Text="Абонент:" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBlock Text="{Binding FullName}"/>

            <TextBlock Text="Адрес:" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBlock Text="{Binding Address}"/>

            <TextBlock Text="Лицевой счет:" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBlock Text="{Binding AccountNumber}"/>

            <Line X1="0" Y1="10" X2="400" Y2="10" Stroke="Black" StrokeThickness="1" Margin="0,10"/>

            <!-- Период -->
            <TextBlock Text="Период оплаты:" FontWeight="Bold"/>
            <TextBlock Text="{Binding PeriodText}"/>

            <Line X1="0" Y1="10" X2="400" Y2="10" Stroke="Black" StrokeThickness="1" Margin="0,10"/>

            <!-- Таблица показаний -->
            <DataGrid ItemsSource="{Binding Readings}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      Height="120">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Счетчик" Binding="{Binding SerialNumber}" Width="100"/>
                    <DataGridTextColumn Header="Текущее" Binding="{Binding CurrentReading}" Width="70"/>
                    <DataGridTextColumn Header="Предыдущее" Binding="{Binding PreviousReading}" Width="70"/>
                    <DataGridTextColumn Header="Расход" Binding="{Binding Consumption}" Width="60"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:F2}}"/>
                </DataGrid.Columns>
            </DataGrid>

            <Line X1="0" Y1="10" X2="400" Y2="10" Stroke="Black" StrokeThickness="1" Margin="0,10"/>

            <!-- Итого -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Тариф:" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="{Binding TariffText}" HorizontalAlignment="Right"/>

                <TextBlock Grid.Column="0" Text="Начислено:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBlock Grid.Column="1" Text="{Binding AccrualAmount, StringFormat={}{0:F2} ₽}" HorizontalAlignment="Right" Margin="0,5,0,0"/>

                <TextBlock Grid.Column="0" Text="Оплачено:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBlock Grid.Column="1" Text="{Binding PaidAmount, StringFormat={}{0:F2} ₽}" HorizontalAlignment="Right" Margin="0,5,0,0"/>

                <TextBlock Grid.Column="0" Text="Задолженность:" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBlock Grid.Column="1" Text="{Binding DebtAmount, StringFormat={}{0:F2} ₽}" 
                           HorizontalAlignment="Right" Margin="0,10,0,0"
                           Foreground="{Binding DebtColor}"/>
            </Grid>

            <Line X1="0" Y1="10" X2="400" Y2="10" Stroke="Black" StrokeThickness="1" Margin="0,10"/>

            <!-- Низ -->
            <TextBlock Text="Спасибо за своевременную оплату!" 
                       FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>

            <TextBlock Text="Подпись: ___________" 
                       FontSize="12" HorizontalAlignment="Right" Margin="0,20,0,0"/>
        </StackPanel>
    </Border>
</Window>