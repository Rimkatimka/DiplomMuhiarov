<UserControl x:Class="EnergyMeteringSystem.App.Views.Reports.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор типа отчёта простыми кнопками -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Потребление" 
                    Command="{Binding RefreshCommand}"
                    CommandParameter="0"
                    Width="120" Margin="5" Padding="5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedReportType}" Value="0">
                                <Setter Property="Background" Value="#1976D2"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Начисления/Оплаты" 
                    Command="{Binding RefreshCommand}"
                    CommandParameter="1"
                    Width="120" Margin="5" Padding="5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedReportType}" Value="1">
                                <Setter Property="Background" Value="#1976D2"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Задолженность" 
                    Command="{Binding RefreshCommand}"
                    CommandParameter="2"
                    Width="120" Margin="5" Padding="5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedReportType}" Value="2">
                                <Setter Property="Background" Value="#1976D2"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Параметры отчёта -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <!-- Для отчёта по потреблению -->
            <StackPanel Orientation="Horizontal" 
                        Visibility="{Binding ConsumptionVisibility}">
                <TextBlock Text="С:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="120" Margin="5"/>
                <TextBlock Text="По:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="120" Margin="5"/>
            </StackPanel>

            <!-- Для отчёта по начислениям -->
            <StackPanel Orientation="Horizontal" 
                        Visibility="{Binding AccrualVisibility}">
                <TextBlock Text="Год:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox ItemsSource="{Binding Years}" 
                          SelectedItem="{Binding SelectedYear}"
                          Width="80" Margin="5"/>
                <TextBlock Text="Месяц:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox ItemsSource="{Binding Months}" 
                          SelectedIndex="{Binding SelectedMonth}" 
                          Width="100" Margin="5"/>
            </StackPanel>

            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}"
                    Padding="10,5" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Данные отчёта -->
        <Grid Grid.Row="2">
            <!-- Отчёт по потреблению -->
            <DataGrid Visibility="{Binding ConsumptionVisibility}"
                      ItemsSource="{Binding ConsumptionData}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                    <DataGridTextColumn Header="Счётчик" Binding="{Binding MeterSerial}" Width="120"/>
                    <DataGridTextColumn Header="Период" Width="200">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0:dd.MM.yyyy} - {1:dd.MM.yyyy}">
                                <Binding Path="StartDate"/>
                                <Binding Path="EndDate"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Потребление" Binding="{Binding Consumption}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Отчёт по начислениям -->
            <DataGrid Visibility="{Binding AccrualVisibility}"
                      ItemsSource="{Binding AccrualData}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                    <DataGridTextColumn Header="Начислено" Binding="{Binding AccrualAmount, StringFormat={}{0:F2} ₽}" Width="120"/>
                    <DataGridTextColumn Header="Оплачено" Binding="{Binding PaidAmount, StringFormat={}{0:F2} ₽}" Width="120"/>
                    <DataGridTextColumn Header="Долг" Binding="{Binding DebtAmount, StringFormat={}{0:F2} ₽}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Отчёт по долгам -->
            <DataGrid Visibility="{Binding DebtVisibility}"
                      ItemsSource="{Binding DebtData}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                    <DataGridTextColumn Header="Сумма долга" Binding="{Binding DebtAmount, StringFormat={}{0:F2} ₽}" Width="120"/>
                    <DataGridTextColumn Header="Период" Binding="{Binding PeriodMonth}" Width="100"/>
                    <DataGridTextColumn Header="Год" Binding="{Binding PeriodYear}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Итоги и экспорт -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="Итого: " FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>

            <TextBlock Text="{Binding TotalConsumption, StringFormat={}{0:F2}}" 
                       Visibility="{Binding ConsumptionVisibility}"
                       FontSize="14" FontWeight="Bold" Foreground="Blue" Margin="5,0"/>

            <TextBlock Text="{Binding TotalAccrual, StringFormat={}{0:F2} ₽}" 
                       Visibility="{Binding AccrualVisibility}"   
                       FontSize="14" FontWeight="Bold" Foreground="Blue" Margin="5,0"/>

            <TextBlock Text="{Binding TotalDebtSum, StringFormat={}{0:F2} ₽}" 
                       Visibility="{Binding DebtVisibility}"   
                       FontSize="14" FontWeight="Bold" Foreground="Red" Margin="5,0"/>

            <Button Content="Экспорт в Excel" 
                    Command="{Binding ExportCommand}"
                    Padding="15,5" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>