<UserControl x:Class="EnergyMeteringSystem.App.Views.Reports.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор типа отчета -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <RadioButton Content="Потребление" 
                 IsChecked="{Binding IsConsumptionReport}"
                 GroupName="ReportType"
                 Margin="5" Padding="5"/>
            <RadioButton Content="Начисления" 
                 IsChecked="{Binding IsAccrualReport}"
                 GroupName="ReportType"
                 Margin="5" Padding="5"/>
            <RadioButton Content="Задолженность" 
                 IsChecked="{Binding IsDebtReport}"
                 GroupName="ReportType"
                 Margin="5" Padding="5"/>
        </StackPanel>

        <!-- Параметры отчета -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Visibility="{Binding ConsumptionVisibility}">
                    <TextBlock Text="Период:" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="С:" VerticalAlignment="Center" Margin="5"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Width="120" Margin="5"/>
                        <TextBlock Text="по:" VerticalAlignment="Center" Margin="5"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Width="120" Margin="5"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Visibility="{Binding AccrualVisibility}">
                    <TextBlock Text="Параметры начислений" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Год:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox ItemsSource="{Binding Years}" 
                  SelectedItem="{Binding SelectedYear}"
                  Width="80" Margin="5"/>
                        <TextBlock Text="Месяц:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox ItemsSource="{Binding Months}" 
                  SelectedItem="{Binding SelectedMonthName}"
                  Width="100" Margin="5"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Visibility="{Binding DebtVisibility}">
                    <TextBlock Text="Актуально на текущую дату" FontWeight="Bold" Margin="0,5,0,5"/>
                </StackPanel>

                <Button Content="Обновить" 
                        Command="{Binding RefreshCommand}"
                        Width="100" Margin="5" HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

        <!-- Одна таблица с авто-генерацией колонок -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding ReportData}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Margin="0,0,0,10"
                  Background="White"/>

        <!-- Кнопка экспорта -->
        <Button Grid.Row="3" 
                Content="Экспорт в Excel" 
                Command="{Binding ExportCommand}"
                Width="150" Height="30" 
                Margin="5" HorizontalAlignment="Right"
                Background="#4CAF50" Foreground="White"/>
    </Grid>
</UserControl>