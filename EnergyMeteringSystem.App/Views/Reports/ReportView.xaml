<UserControl x:Class="EnergyMeteringSystem.App.Views.Reports.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор типа отчета -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <RadioButton Content="Потребление" 
                         IsChecked="{Binding IsConsumptionReport}"
                         GroupName="ReportType"
                         Margin="5" Padding="5"/>
            <RadioButton Content="Начисления" 
                         IsChecked="{Binding IsAccrualReport}"
                         GroupName="ReportType"
                         Margin="5" Padding="5"/>
            <RadioButton Content="Задолженность" 
                         IsChecked="{Binding IsDebtReport}"
                         GroupName="ReportType"
                         Margin="5" Padding="5"/>
        </StackPanel>

        <!-- Параметры отчета -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <!-- Для потребления -->
            <StackPanel Orientation="Horizontal" 
                        Visibility="{Binding IsConsumptionReport, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="С:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="100" Margin="5"/>
                <TextBlock Text="по:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="100" Margin="5"/>
            </StackPanel>

            <!-- Для начислений -->
            <StackPanel Orientation="Horizontal" 
                        Visibility="{Binding IsAccrualReport, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Год:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox ItemsSource="{Binding Years}" 
                          SelectedItem="{Binding SelectedYear}"
                          Width="70" Margin="5"/>
                <TextBlock Text="Месяц:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox ItemsSource="{Binding Months}" 
                          SelectedItem="{Binding SelectedMonthName}"
                          Width="90" Margin="5"/>
            </StackPanel>

            <!-- Для задолженности -->
            <TextBlock Visibility="{Binding IsDebtReport, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Text="Текущая задолженность" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center" 
                       Margin="5"/>

            <!-- Кнопка обновить -->
            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}"
                    Padding="10,3" Margin="10,0,0,0"
                    Background="#2196F3" Foreground="White"/>
        </StackPanel>

        <!-- ИНДИКАТОР КОЛИЧЕСТВА ЗАПИСЕЙ (для отладки) -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
            <Border Background="#E3F2FD" CornerRadius="3" Padding="5">
                <TextBlock>
                    <Run Text="Найдено записей: "/>
                    <Run Text="{Binding ConsumptionData.Count, Mode=OneWay}" 
                         Foreground="Blue" FontWeight="Bold"/>
                    <Run Text=" (потребление)"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Таблица с данными (упрощенная для проверки) -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding ConsumptionData}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Margin="0,0,0,10"
                  Background="White">
        </DataGrid>

        <!-- Кнопка экспорта -->
        <Button Grid.Row="4" 
                Content="Экспорт в Excel" 
                Command="{Binding ExportCommand}"
                Width="150" Height="30" 
                Margin="5" HorizontalAlignment="Right"
                Background="#4CAF50" Foreground="White"/>
    </Grid>
</UserControl>