<UserControl x:Class="EnergyMeteringSystem.App.Views.Admin.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" Padding="5"
                     VerticalAlignment="Center"/>
            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}" 
                    Margin="10,0,0,0"
                    Padding="10,5"/>
        </StackPanel>

        <!-- Таблица пользователей -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding FilteredUsers}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding RoleText}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style>
                            <Setter Property="TextBlock.Foreground" Value="{Binding StatusColor}"/>
                            <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Создан" Binding="{Binding CreatedText}" Width="100"/>
                <DataGridTextColumn Header="Последний вход" Binding="{Binding LastLoginText}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" 
                    Command="{Binding AddCommand}"
                    Padding="15,5" Margin="5"/>
            <Button Content="Редактировать" 
                    Command="{Binding EditCommand}"
                    Padding="15,5" Margin="5"/>
            <Button Content="Блокировать/Разблокировать" 
                    Command="{Binding BlockCommand}"
                    Padding="15,5" Margin="5"/>
            <Button Content="Сброс пароля" 
                    Command="{Binding ResetPasswordCommand}"
                    Padding="15,5" Margin="5"
                    Background="#FF9800" Foreground="White"/>
        </StackPanel>
    </Grid>
</UserControl>