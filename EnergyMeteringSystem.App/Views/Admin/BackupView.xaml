<UserControl x:Class="EnergyMeteringSystem.App.Views.Admin.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Резервное копирование базы данных" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Выбор пути -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBox Text="{Binding BackupPath}" 
                     Width="400" Padding="5" Margin="5"
                     IsReadOnly="True"/>
            <Button Content="Обзор" 
                    Command="{Binding BrowseCommand}"
                    Padding="15,5" Margin="5"/>
        </StackPanel>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Content="Создать резервную копию" 
                    Command="{Binding CreateBackupCommand}"
                    Padding="20,10" Margin="10"
                    Background="#4CAF50" Foreground="White"
                    Width="200"/>

            <Button Content="Восстановить из копии" 
                    Command="{Binding RestoreCommand}"
                    Padding="20,10" Margin="10"
                    Background="#FF9800" Foreground="White"
                    Width="200"/>
        </StackPanel>

        <!-- Статус -->
        <Border Grid.Row="3" Background="#F5F5F5" Padding="10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Статус:" FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,5,0,0"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}" 
                             Height="5" Margin="0,10,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>