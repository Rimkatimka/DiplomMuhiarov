<UserControl x:Class="EnergyMeteringSystem.App.Views.Admin.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="С:" VerticalAlignment="Center" Margin="5"/>
            <DatePicker SelectedDate="{Binding FromDate}" Width="120" Margin="5"/>
            <TextBlock Text="По:" VerticalAlignment="Center" Margin="5"/>
            <DatePicker SelectedDate="{Binding ToDate}" Width="120" Margin="5"/>

            <Button Content="Применить" 
                    Command="{Binding RefreshCommand}"
                    Padding="10,5" Margin="5"/>
            <Button Content="Сброс" 
                    Command="{Binding ClearFilterCommand}"
                    Padding="10,5" Margin="5"/>

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="200" Padding="5" Margin="20,0,0,0"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Таблица логов -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding FilteredLogs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Время" Binding="{Binding TimeText}" Width="150"/>
                <DataGridTextColumn Header="Пользователь" Binding="{Binding UserDisplay}" Width="150"/>
                <DataGridTextColumn Header="Действие" Binding="{Binding ActionText}" Width="120"/>
                <DataGridTextColumn Header="Таблица" Binding="{Binding TableName}" Width="120"/>
                <DataGridTextColumn Header="ID записи" Binding="{Binding RecordId}" Width="80"/>
                <DataGridTextColumn Header="Детали" Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>