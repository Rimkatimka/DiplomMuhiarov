<Window x:Class="EnergyMeteringSystem.App.Views.Shared.ExportFormatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор формата экспорта" 
        Height="150" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="20">
        <TextBlock Text="Выберите формат экспорта:" FontWeight="Bold" Margin="0,0,0,15"/>

        <RadioButton x:Name="ExcelRadio" Content="Microsoft Excel (.xlsx)" IsChecked="True" Margin="0,5" GroupName="Format"/>
        <RadioButton x:Name="PdfRadio" Content="PDF документ (.pdf)" Margin="0,5" GroupName="Format"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Click="Ok_Click" Width="80" Margin="5" Background="#4CAF50" Foreground="White"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80" Margin="5"/>
        </StackPanel>
    </StackPanel>
</Window>