<UserControl x:Class="EnergyMeteringSystem.App.Views.Contracts.ContractEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Номер договора -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер договора:" Margin="5" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" 
           Text="{Binding DateError}"
           Foreground="Red"
           FontSize="12"
           Margin="5"
           HorizontalAlignment="Center"
           Visibility="{Binding DateError}"/>

        <!-- Объект -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Объект:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="1" Grid.Column="1" 
                  ItemsSource="{Binding Objects}"
                  SelectedItem="{Binding SelectedObject}"
                  DisplayMemberPath="Address"
                  Margin="5" Padding="5"/>

        <!-- Дата договора -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата договора:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding ContractDate}" Margin="5"/>

        <!-- Дата начала -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Начало действия:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding StartDate}" Margin="5"/>

        <!-- Дата окончания -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Окончание:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding EndDate}" Margin="5"/>

        <!-- Тариф -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Тариф:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="5" Grid.Column="1" 
                  ItemsSource="{Binding Tariffs}"
                  SelectedItem="{Binding SelectedTariff}"
                  DisplayMemberPath="Name"
                  Margin="5" Padding="5"/>

        <!-- Статус -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Статус:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="6" Grid.Column="1" 
                  ItemsSource="{Binding Statuses}"
                  SelectedItem="{Binding SelectedStatus}"
                  DisplayMemberPath="Name"
                  Margin="5" Padding="5"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Command="{Binding SaveCommand}"
                    Padding="20,8" Margin="5"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Отмена" 
                    Command="{Binding CancelCommand}"
                    Padding="20,8" Margin="5"/>
        </StackPanel>
    </Grid>
</UserControl>