<UserControl x:Class="EnergyMeteringSystem.App.Views.Objects.ObjectMetersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding ObjectTitle}" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

        <!-- Таблица счетчиков -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Meters}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  AlternationCount="2"
                  BorderBrush="LightGray"
                  BorderThickness="1">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2D3F5E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Height" Value="35"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Серийный номер" 
                                    Binding="{Binding SerialNumber}" 
                                    Width="2*"/>
                <DataGridTextColumn Header="Тип счетчика" 
                                    Binding="{Binding MeterTypeName}" 
                                    Width="2*"/>
                <DataGridTextColumn Header="Статус" 
                                    Binding="{Binding StatusName}" 
                                    Width="1*"/>
                <DataGridTextColumn Header="Дата установки" 
                                    Binding="{Binding InstallationDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="1*"/>
                <DataGridTextColumn Header="Поверка до" 
                                    Binding="{Binding NextVerificationDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="1*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка закрытия -->
        <Button Grid.Row="2" 
                Content="Закрыть"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Padding="20,5"
                Background="#F44336"
                Foreground="White"
                BorderThickness="0"
                Width="100"/>
    </Grid>
</UserControl>