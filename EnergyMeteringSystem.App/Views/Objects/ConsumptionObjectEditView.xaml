<Window x:Class="EnergyMeteringSystem.App.Views.Objects.ConsumptionObjectEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление объекта" 
        Height="350" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Улица -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Улица:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="0" Grid.Column="1" 
                  ItemsSource="{Binding Streets}"
                  SelectedItem="{Binding SelectedStreet}"
                  DisplayMemberPath="Name"
                  Margin="5" Padding="5"/>

        <!-- Номер дома -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Номер дома:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" 
                 Text="{Binding HouseNumber}" 
                 Margin="5" Padding="5"/>

        <!-- Номер квартиры -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Номер квартиры:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" 
                 Text="{Binding ApartmentNumber}" 
                 Margin="5" Padding="5"/>

        <!-- Тип объекта -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Тип объекта:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" 
                  ItemsSource="{Binding ObjectTypes}"
                  SelectedItem="{Binding SelectedObjectType}"
                  DisplayMemberPath="Name"
                  Margin="5" Padding="5"/>

        <!-- Общая площадь -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Общая площадь (м²):" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" 
                 Text="{Binding TotalArea}" 
                 Margin="5" Padding="5"/>

        <!-- Количество жильцов -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Количество жильцов:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="5" Grid.Column="1" 
                 Text="{Binding ResidentCount}" 
                 Margin="5" Padding="5"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Command="{Binding SaveCommand}"
                     Margin="5"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Отмена" 
                    Command="{Binding CancelCommand}"
                     Margin="5"/>
        </StackPanel>
    </Grid>
</Window>