<UserControl x:Class="EnergyMeteringSystem.App.Views.Analytics.HierarchyAnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:local="clr-namespace:EnergyMeteringSystem.App.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Выбор периода -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Год:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Years}" 
                      SelectedItem="{Binding SelectedYear}"
                      Width="80" Margin="5"/>

            <TextBlock Text="Месяц:" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <ComboBox ItemsSource="{Binding Months}" 
                      SelectedItem="{Binding SelectedMonthName}"
                      Width="100" Margin="5"/>

            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}"
                    Padding="10,5" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Кнопка назад при просмотре региона -->
        <Button Grid.Row="1" 
                Content="← Назад к списку регионов"
                Command="{Binding BackToRegionsCommand}"
                HorizontalAlignment="Left"
                Padding="10,5"
                Margin="0,0,0,10"
                Visibility="{Binding ShowRegionDetail, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Список регионов (основной вид) -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Regions}"
                  SelectedItem="{Binding SelectedRegion}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Visibility="{Binding ShowRegionDetail, Converter={StaticResource InverseBooleanConverter}}">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}"/>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}"/>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Регион" Binding="{Binding RegionName}" Width="200"/>
                <DataGridTextColumn Header="Потребление (кВт·ч)" Binding="{Binding TotalConsumption, StringFormat={}{0:F0}}" Width="150"/>
                <DataGridTextColumn Header="Кол-во объектов" Binding="{Binding ObjectsCount}" Width="120"/>
                <DataGridTextColumn Header="Среднее на объект" Binding="{Binding AveragePerObject, StringFormat={}{0:F0} кВт·ч}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Детальный вид региона -->
        <ScrollViewer Grid.Row="2" 
                      Visibility="{Binding ShowRegionDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <!-- Информация о регионе -->
                <Border Background="#E3F2FD" Padding="15" CornerRadius="5" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedRegionData.RegionName}" 
                                   FontSize="20" FontWeight="Bold"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2196F3" Padding="10" CornerRadius="5" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Общее потребление" Foreground="White" FontSize="11"/>
                                    <TextBlock Text="{Binding SelectedRegionData.TotalConsumption, StringFormat={}{0:F0} кВт·ч}" 
                                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#4CAF50" Padding="10" CornerRadius="5" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Кол-во объектов" Foreground="White" FontSize="11"/>
                                    <TextBlock Text="{Binding SelectedRegionData.ObjectsCount}" 
                                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#FF9800" Padding="10" CornerRadius="5" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Среднее на объект" Foreground="White" FontSize="11"/>
                                    <TextBlock Text="{Binding SelectedRegionData.AveragePerObject, StringFormat={}{0:F0} кВт·ч}" 
                                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ТОП-10 объектов региона -->
                <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ТОП-10 объектов по потреблению" 
                                   FontSize="16" FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <DataGrid ItemsSource="{Binding TopObjects}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="200"/>
                                <DataGridTextColumn Header="Дом" Binding="{Binding HouseNumber}" Width="80"/>
                                <DataGridTextColumn Header="Кв." Binding="{Binding ApartmentNumber}" Width="60"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding ObjectType}" Width="100"/>
                                <DataGridTextColumn Header="Потребление" Binding="{Binding Consumption, StringFormat={}{0:F0} кВт·ч}" Width="120"/>
                                <DataGridTextColumn Header="% от региона" Binding="{Binding Percentage, StringFormat={}{0:F1}%}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Детали по городам -->
                <Border Background="#F5F5F5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Потребление по городам" 
                                   FontSize="16" FontWeight="Bold" 
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding SelectedRegionData.Cities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Margin="0,0,0,5">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <TextBlock Text="{Binding CityName}" FontWeight="Bold" Width="150"/>
                                                <TextBlock Text="{Binding TotalConsumption, StringFormat=Потребление: {0:F0} кВт·ч}" 
                                                           Foreground="#2196F3" Width="180"/>
                                                <TextBlock Text="{Binding ObjectsCount, StringFormat=Объектов: {0}}" 
                                                           Foreground="#4CAF50" Width="120"/>
                                            </StackPanel>
                                        </Expander.Header>

                                        <StackPanel Margin="20,10,0,10">
                                            <ItemsControl ItemsSource="{Binding Streets}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Expander Margin="0,0,0,3">
                                                            <Expander.Header>
                                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                                    <TextBlock Text="{Binding StreetName}" FontWeight="Bold" Width="150"/>
                                                                    <TextBlock Text="{Binding TotalConsumption, StringFormat=Потребление: {0:F0} кВт·ч}" 
                                                                               Foreground="#FF9800" Width="180"/>
                                                                    <TextBlock Text="{Binding ObjectsCount, StringFormat=Объектов: {0}}" 
                                                                               Foreground="#4CAF50" Width="120"/>
                                                                </StackPanel>
                                                            </Expander.Header>

                                                            <DataGrid ItemsSource="{Binding Objects}"
                                                                      AutoGenerateColumns="False"
                                                                      IsReadOnly="True"
                                                                      Margin="20,5,0,5">
                                                                <DataGrid.Columns>
                                                                    <DataGridTextColumn Header="Дом" Binding="{Binding HouseNumber}" Width="80"/>
                                                                    <DataGridTextColumn Header="Кв." Binding="{Binding ApartmentNumber}" Width="60"/>
                                                                    <DataGridTextColumn Header="Тип" Binding="{Binding ObjectType}" Width="100"/>
                                                                    <DataGridTextColumn Header="Потребление" Binding="{Binding Consumption, StringFormat={}{0:F0} кВт·ч}" Width="120"/>
                                                                    <DataGridTextColumn Header="% от региона" Binding="{Binding Percentage, StringFormat={}{0:F1}%}" Width="100"/>
                                                                </DataGrid.Columns>
                                                            </DataGrid>
                                                        </Expander>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>