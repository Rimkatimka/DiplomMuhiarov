<UserControl x:Class="EnergyMeteringSystem.App.Views.Analytics.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Год:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Years}" 
                      SelectedItem="{Binding SelectedYear}"
                      Width="80" Margin="5"/>

            <TextBlock Text="Месяц:" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <ComboBox ItemsSource="{Binding Months}" 
                      SelectedItem="{Binding SelectedMonthName}"
                      Width="100" Margin="5"/>

            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}"
                    Padding="10,5" Margin="15,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F5F5F5" Padding="10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="ТОП-10 объектов по потреблению" 
                               FontSize="14" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <lvc:CartesianChart Series="{Binding TopObjectsSeries}" 
                                        LegendLocation="Right"
                                        Height="300"
                                        DisableAnimations="True">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Потребление (кВт·ч)" 
                                      LabelFormatter="{Binding XFormatter}"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Объект" Labels="{Binding TopObjectsLabels}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Распределение по типам объектов" 
                               FontSize="14" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <lvc:PieChart Series="{Binding TypeDistributionSeries}" 
                                  Height="300"
                                  LegendLocation="Right"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E3F2FD" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#2196F3" Padding="15,10" CornerRadius="5" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Общее потребление" Foreground="White" FontSize="11"/>
                        <TextBlock Text="{Binding TotalConsumption, StringFormat={}{0:F0} кВт·ч}" 
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#4CAF50" Padding="15,10" CornerRadius="5" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Среднее на объект" Foreground="White" FontSize="11"/>
                        <TextBlock Text="{Binding AverageConsumption, StringFormat={}{0:F0} кВт·ч}" 
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#FF9800" Padding="15,10" CornerRadius="5" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Максимум" Foreground="White" FontSize="11"/>
                        <TextBlock Text="{Binding MaxConsumption, StringFormat={}{0:F0} кВт·ч}" 
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding TopObjects}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MaxHeight="250">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Rank}" Width="50"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="300"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding ObjectType}" Width="100"/>
                <DataGridTextColumn Header="Потребление (кВт·ч)" Binding="{Binding Consumption}" Width="120"/>
                <DataGridTextColumn Header="% от общего" Binding="{Binding Percentage, StringFormat={}{0:F1}%}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>